rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- FUNKCJE POMOCNICZE ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'admin@ksef.pl' || 
        request.auth.token.email == 'krzysztof.sobczak@sp-partner.eu'
      );
    }

    // --- REGUŁY ---

    // Faktury: Każdy zalogowany może czytać, tylko admin może pisać
    match /invoices/{invoiceId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Profile użytkowników: Admin widzi wszystkich, użytkownik tylko siebie (do celów logowania)
    match /userProfiles/{userId} {
      allow read: if isSignedIn() && (isAdmin() || request.auth.uid == userId);
      allow write: if isSignedIn() && (isAdmin() || request.auth.uid == userId);
    }
    
    // Blokada pozostałych
    match /{document=**} {
      allow read, write: if false;
    }
  }
}